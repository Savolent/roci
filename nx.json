{
	"$schema": "./node_modules/nx/schemas/nx-schema.json",
	"namedInputs": {
		"default": ["{projectRoot}/**/*", "!{projectRoot}/dist/**/*"],
		"production": ["default", "!{projectRoot}/**/*.test.ts", "!{projectRoot}/**/*.spec.ts"]
	},
	"targetDefaults": {
		"build": {
			"dependsOn": ["^build"],
			"inputs": ["production"],
			"outputs": ["{projectRoot}/dist"],
			"cache": true
		},
		"typecheck": {
			"dependsOn": ["^build"],
			"inputs": ["default"],
			"cache": true
		},
		"test": {
			"inputs": ["default"],
			"cache": true
		},
		"lint": {
			"inputs": ["default"],
			"cache": true
		}
	}
}
